# Chemical Paper Search 환경 변수

# Semantic Scholar API key (선택). 없으면 무인증 호출로 HTTP 429 발생 가능
SEMANTIC_SCHOLAR_API_KEY=""

# Crossref polite pool 식별용 이메일 (권장)
CROSSREF_MAILTO="developer@example.com"

# OpenAlex polite pool 식별용 이메일 (선택, 미설정 시 CROSSREF_MAILTO 사용)
OPENALEX_MAILTO=""

# provider 응답 캐시 디렉터리 (선택)
CHEMICAL_SEARCH_CACHE_DIR="output/chemical-search/cache"

# Next.js rewrite 대상 FastAPI 주소 (선택, 기본 http://127.0.0.1:8000)
CHEMICAL_API_URL="http://127.0.0.1:8000"

# 한국 특허(KIPRIS) 검색용 서비스 키 (선택)
# data.go.kr '특허실용신안 정보 검색 서비스' 활용신청으로 발급한다.
# 미설정 시 KIPRIS 한국 특허 소스는 비활성화된다(오류 아님, providers[]/patents[]에서 제외).
# 한글 물질명 입력(Wikidata)은 별도 키가 필요 없다.
KIPRIS_SERVICE_KEY=""
