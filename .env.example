# Chemical Paper Search 환경 변수
#
# 변수는 두 곳에 나뉘어 들어간다(배포 토폴로지는 DEPLOYMENT.md 참고):
#   - 프론트엔드(Vercel): Next.js 앱이 읽는 변수. NEXT_PUBLIC_* 는 브라우저에 노출됨(의도된 동작).
#   - 백엔드(Hugging Face Space): FastAPI가 읽는 외부 API 키/식별자.
# 로컬 개발에서는 이 파일 하나에 모두 넣어도 동작한다.

# ── 프론트엔드(Vercel) ─────────────────────────────────────────────
# Supabase 프로젝트 URL과 anon(공개) 키. 둘 다 필수 — 미설정 시 로그인 게이트가 동작하지 않는다.
# anon 키는 설계상 공개 키다(NEXT_PUBLIC 접두사로 브라우저에 노출되며, 접근 제어는 RLS가 담당).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# private Hugging Face Space(FastAPI 백엔드) 공개 URL (프론트엔드/Vercel).
# 미설정 시 http://127.0.0.1:8000(로컬)로 프록시한다. 프록시 라우트가 런타임에 읽으므로 URL 변경 시 재빌드 불필요.
CHEMICAL_API_URL="http://127.0.0.1:8000"

# private HF Space를 호출하기 위한 Bearer 토큰 (프론트엔드/Vercel). HF read 토큰을 넣는다.
# 프록시 라우트가 서버 측에서 Authorization: Bearer <token> 헤더로 주입한다(브라우저에는 노출되지 않음).
# 로컬에서 백엔드를 인증 없이 띄울 때는 비워 둔다.
CHEMICAL_API_TOKEN=""

# ── 백엔드(Hugging Face Space) ─────────────────────────────────────
# Semantic Scholar API key (선택). 미설정 시 기본 source에서 제외된다(무인증 호출은 HTTP 429가 잦음).
SEMANTIC_SCHOLAR_API_KEY=""

# Crossref polite pool 식별용 이메일 (권장)
CROSSREF_MAILTO="developer@example.com"

# OpenAlex polite pool 식별용 이메일 (선택, 미설정 시 CROSSREF_MAILTO 사용)
OPENALEX_MAILTO=""

# provider 응답 캐시 디렉터리 (선택)
CHEMICAL_SEARCH_CACHE_DIR="output/chemical-search/cache"

# 한국 특허(KIPRIS) 검색용 KIPRIS Plus REST AccessKey (선택)
# plus.kipris.or.kr 가입 후 'API KEY 관리'에서 발급한 REST AccessKey를 넣는다.
# 미설정 시 KIPRIS 한국 특허 소스는 비활성화된다(오류 아님, providers[]/patents[]에서 제외).
# 한글 물질명 입력(Wikidata)은 별도 키가 필요 없다.
KIPRIS_SERVICE_KEY=""
